-- Remote Hooking
local remote, f_raw = nil, nil
local c = {nil, nil, nil, nil, nil, nil, nil}

local mt = getrawmetatable(game)
local old = mt.__index
setreadonly(mt, false)
mt.__index = newcclosure(function(self, key)
    if key == "FireServer" or key == "InvokeServer" then
        return function(instance, ...)
            local args = {...}
            if #args >= 4 then
                remote = instance
                f_raw = old(instance, "FireServer")
                for i = 1, 7 do c[i] = args[i] end
            end
            return old(self, key)(instance, ...)
        end
    end
    return old(self, key)
end)
setreadonly(mt, true)

-- [ CÁC HÀM THỰC THI ]
function System.parry.execute()
    if not (remote and f_raw) then return end
    local cam = workspace.CurrentCamera
    local char = LocalPlayer.Character
    if not (char and char:FindFirstChild("HumanoidRootPart")) then return end
    
    local camCF = cam.CFrame
    local events = {}
    local Alive = workspace:FindFirstChild("Alive")
    if Alive then
        for _, v in ipairs(Alive:GetChildren()) do
            if v ~= char and v.PrimaryPart then
                local screenPos, isOnScreen = cam:WorldToScreenPoint(v.PrimaryPart.Position)
                if isOnScreen then events[tostring(v)] = screenPos end
            end
        end
    end
    c[3], c[4], c[5], c[6] = camCF.LookVector, camCF, events, {cam.ViewportSize.X/2, cam.ViewportSize.Y/2}
    pcall(function() f_raw(remote, unpack(c)) end)
end

function System.animation.spam_sequence()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        for _, track in pairs(char.Humanoid:GetPlayingAnimationTracks()) do
            if track.Name:lower():find("parry") or track.Name:lower():find("slash") then track:Stop() end
        end
    end
end

