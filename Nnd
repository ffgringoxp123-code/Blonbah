-- [ PHẦN 3: LOGIC BALL STATS & PING ]
local peakVal = 0
local lastBall = nil

task.spawn(function()
    while task.wait(0.01) do
        -- Cập nhật Ping
        local ping = math.floor(StatsService.Network.ServerStatsItem["Data Ping"]:GetValue())
        PingLabel.Text = "Ping: " .. ping .. " ms"
        
        -- Cập nhật Ball Stats
        local balls = workspace:FindFirstChild("Balls")
        local activeBall = nil
        local maxSpeed = 0
        if balls then
            for _, b in ipairs(balls:GetChildren()) do
                if b:IsA("BasePart") then
                    local s = b.Velocity.Magnitude
                    if s > maxSpeed then maxSpeed = s activeBall = b end
                end
            end
        end

        if activeBall then
            if activeBall ~= lastBall then peakVal = 0 lastBall = activeBall end
            if maxSpeed > peakVal then peakVal = maxSpeed end
            CurrentSpeed.Text = string.format("%.1f", maxSpeed)
            PeakSpeed.Text = string.format("%.1f", peakVal)
        else
            CurrentSpeed.Text = "0.0"
        end
    end
end)

-- [ PHẦN 4: LOGIC TRIGGER & SPAM CONTROL ]
local listening = false
KeyButton.MouseButton1Click:Connect(function()
    listening = true
    KeyButton.Text = "..."
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if listening and input.UserInputType == Enum.UserInputType.Keyboard then
        currentKey = input.KeyCode
        KeyButton.Text = "[ " .. input.KeyCode.Name .. " ]"
        listening = false
    end
end)

-- Vòng lặp Triggerbot
local function runTriggerbot()
    local balls = workspace:FindFirstChild("Balls")
    if not balls then return end
    for _, b in ipairs(balls:GetChildren()) do
        local target = b:GetAttribute("target") or (b:FindFirstChild("Target") and b.Target.Value)
        if target == LocalPlayer.Name then
            System.parry.execute()
            if System.__properties.ManualSpamAnimationFix then System.animation.spam_sequence() end
        end
    end
end

-- Vòng lặp chính (Heartbeat) - Điều khiển 3 chế độ đồng thời
RunService.Heartbeat:Connect(function()
    local isPressed = not listening and UserInputService:IsKeyDown(currentKey)

    if isPressed then
        if not spamActive then
            spamActive = true
            System.__properties.__manual_spam_enabled = true
            manualSpamStartTick = tick()
            lastManualSpamTick = tick()
            MainStroke.Color = Color3.fromRGB(255, 255, 255)
        end

        local now = tick()

        -- 1. Manual 1 (Kittylol Gốc)
        if now - lastSpamTime_Manual1 >= spamInterval_Manual1 then
            lastSpamTime_Manual1 = now
            System.parry.execute()
        end

        -- 2. Manual 2 (System Loop bù trừ gia tốc)
        local baseRate = System.__properties.__spam_rate
        local elapsed = now - manualSpamStartTick
        local accelFactor = math.min(1 + (elapsed / 0.5) * 0.5, 1.5)
        local interval = 1 / (baseRate * accelFactor)
        
        if now - lastManualSpamTick >= interval then
            lastManualSpamTick = now
            System.parry.execute()
            if System.__properties.ManualSpamAnimationFix then System.animation.spam_sequence() end
        end

        -- 3. Triggerbot
        runTriggerbot()

    else
        if spamActive then
            spamActive = false
            System.__properties.__manual_spam_enabled = false
            MainStroke.Color = Color3.fromRGB(255, 105, 180)
        end
    end
end)

